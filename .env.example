# ─────────────────────────────────────────────────────────
# BACKEND SELECTOR — cambiar este valor para elegir backend
# Opciones: "supabase" | "azure"
# ─────────────────────────────────────────────────────────
REACT_APP_BACKEND=supabase

# ── Supabase (gratis, sin suscripción) ───────────────────
# Obtener en: app.supabase.com → tu proyecto → Settings → API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Azure (para equipos con suscripción corporativa) ─────
# Dejar vacío si usás Supabase
REACT_APP_AZURE_API_BASE=https://tu-app.azurestaticapps.net/api
